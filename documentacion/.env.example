
# Dominio publico (debe apuntar al droplet por DNS A record)
FORGEJO_DOMAIN=gitserver.clevercloud.app

# Puerto externo para git por SSH (NO uses 22, ese es del droplet)
FORGEJO_SSH_PORT=xxx

# Timeout de migracion en segundos (repos grandes desde Bitbucket)
FORGEJO_GIT_MIGRATE_TIMEOUT=7200

# ---- Postgres ----
POSTGRES_USER=forgejo_admin
POSTGRES_PASSWORD=CHANGE_ME
POSTGRES_DB=forgejo

# ---- SMTP (CRITICO: sin esto no salen invitaciones) ----
# Gmail Workspace recomendado.
# (requiere 2FA activado en la cuenta).
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=devops@clevercloud.mx
SMTP_PASS=CHANGE_ME
SMTP_FROM="Clever Cloud Git <devops@clevercloud.mx>"

# ---- Secretos internos de Forgejo (openssl rand -hex 32) ----
FORGEJO_SECRET_KEY=CHANGE_ME
FORGEJO_INTERNAL_TOKEN=CHANGE_ME
FORGEJO_LFS_JWT_SECRET=CHANGE_ME
